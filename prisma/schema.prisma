generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id          String   @id @default(uuid())
  name        String
  email       String
  channelLink String
  budget      String
  helpText    String
  createdAt   DateTime @default(now())
}
